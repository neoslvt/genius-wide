{
  "name": "Genius Wide",
  "description": "Makes the lyrics on Genius.com wide, removes the 'You might also like' and Tickets.",
  "icons": {
    "256": "icon.png"
  },
  "version": "1.0",
  "manifest_version": 3,
  "browser_specific_settings": {
    "gecko": {
      "id": "geniuswide@geniuswide.com",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.genius.com/*"],
      "js": ["content.js"]
    }
  ]
}